# Application Settings
APP_ENV=development
DEBUG=true
PROJECT_NAME="CampusCopilot API"
API_V1_STR="/api/v1"

# Database Settings
# For local dev: postgresql+asyncpg://postgres:postgres@localhost:5432/campuscopilot
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/db_name

# Firebase Authentication
# Path to firebase service account JSON file, or raw JSON content
FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=

# Vector Database (ChromaDB)
# Can be local persistent path or client host
CHROMA_PERSISTENT_DIR=./chroma_db
CHROMA_HOST=
CHROMA_PORT=

# Google Agent Development Kit (ADK) / GenAI API
# API Key for Google Gemini models
GEMINI_API_KEY=
